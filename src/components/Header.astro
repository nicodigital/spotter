---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import ChevronDown from "./icons/ChevronDown.astro";
import Burger from "./Burger.astro";
import Grid from "./Grid.astro";

interface NavLink {
  label: string;
  href: string;
  hasDropdown?: boolean;
}

const navLinks: NavLink[] = [
  { label: "Monitoreo de seguridad", href: "#monitoreo" },
  { label: "Portería virtual", href: "#porteria" },
  { label: "Tutoriales", href: "#tutoriales" },
  { label: "Preguntas frecuentes", href: "#faq" },
];
---

<header
  class="fixed inset-x-0 top-0 flex h-[100px] items-center justify-center z-100 transition-all duration-400 ease-in-out" data-scroll="top" data-stack="off"
>
  <div class="container transition-all duration-400 ease-in-out">
    <div class="flex w-full items-center justify-between gap-8">
      <div class="min-w-0 flex-1">
        <Logo />
      </div>

      <!-- Desktop Menu -->
      <nav class="menu hidden xg:flex">
        {
          navLinks.map((link) => (
            <a href={link.href}>
              {link.label}
              {link.hasDropdown && <ChevronDown class="size-6" />}
            </a>
          ))
        }
      </nav>

      <div class="hidden min-w-0 flex-1 justify-end xg:flex">
        <Button variant="yellow" size="lg" href="#contacto"> Contacto </Button>
      </div>

      <Burger />
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    class="mobile-menu fixed top-0 left-0 w-full h-[100svh] bg-primary flex flex-col justify-between items-start px-10 gap-8 xg:hidden transition-transform duration-[.4s] ease-in-out z-90"
  >
    <div class="absolute top-[3rem] left-[2rem] z-20">
      <Logo />
    </div>

    <nav class="relative flex flex-col gap-[3rem] z-30 pt-90">
      {
        navLinks.map((link) => (
          <a href={link.href} class="m-item text-xl font-semibold text-white">
            {link.label}
          </a>
        ))
      }
    </nav>
    <div class="pb-30 w-full">
      <Button
      variant="white"
      size="lg"
      href="#contacto"
      class="m-item mt-30 w-full justify-center"
    >
      Contacto
    </Button>
    </div>
    <Grid />
  </div>
</header>

<script>
  import menuMobile from "../js/menuMobile.js";
  menuMobile();
</script>

<style>
  :global(body:not([data-scroll="top"])[data-stack="off"]) header {
    @apply translate-y-[-100%];
  }
  @media (min-width: 992px) {
    :global(body[data-stack="on"]) header .container,
    :global(body:not([data-scroll="top"])) header .container {
      width: 60%;
      background-color: color-mix(
        in srgb,
        var(--color-primary-darker),
        transparent 40%
      ) !important;
      backdrop-filter: blur(10px) !important;
      border-radius: 10rem;
      padding: 4px;
      box-shadow: 0 4px 2rem color-mix(in srgb, #132863, transparent 50%);
    }

    :global(body[data-stack="on"]) header :global(.logo),
    :global(body:not([data-scroll="top"])) header :global(.logo) {
      transform: scale(0.7) translateY(0.5rem) !important;
    }

    :global(body[data-stack="on"]) header :global(a[href="#contacto"]),
    :global(body:not([data-scroll="top"])) header :global(a[href="#contacto"]) {
      transform: scale(0.75) !important;
    }
  }

  /* Mobile Menu Animation */
  :global(.mobile-menu) {
    transform: translateX(100%);
    transition: transform 0.4s ease-in-out;
  }

  :global(body.menu-in) :global(.mobile-menu) {
    transform: translateX(0);
  }

  :global(body.menu-in) :global(main),
  :global(body.menu-in) :global(footer) {
    transform: translateX(-100vw);
  }

  :global(main),
  :global(footer) {
    transition: transform 0.4s ease-in-out;
  }

  :global(body.menu-in) {
    overflow: hidden;
  }
</style>
