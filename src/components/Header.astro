---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import ChevronDown from "./icons/ChevronDown.astro";

interface NavLink {
  label: string;
  href: string;
  hasDropdown?: boolean;
}

const navLinks: NavLink[] = [
  { label: "Monitoreo de seguridad", href: "#monitoreo" },
  { label: "Portería virtual", href: "#porteria" },
  { label: "Tutoriales", href: "#tutoriales" },
  { label: "FAQ", href: "#faq" },
];
---

<header class="fixed container inset-x-0 top-0 flex h-[100px] items-center justify-center z-100">
  <div class="flex w-full items-center justify-between gap-8">
    <div class="min-w-0 flex-1">
      <Logo />
    </div>
    
    <nav class="menu hidden xg:flex">
      {navLinks.map((link) => (
        <a href={link.href}>
          {link.label}
          {link.hasDropdown && <ChevronDown class="size-6" />}
        </a>
      ))}
    </nav>
    
    <div class="hidden min-w-0 flex-1 justify-end xg:flex">
      <Button variant="yellow" size="lg" href="#contacto">
        Contacto
      </Button>
    </div>

    <button class="flex flex-col gap-1 bg-transparent p-2 xg:hidden" aria-label="Abrir menú">
      <span class="block h-[2px] w-6 rounded-[2px] bg-white"></span>
      <span class="block h-[2px] w-6 rounded-[2px] bg-white"></span>
      <span class="block h-[2px] w-6 rounded-[2px] bg-white"></span>
    </button>
  </div>
</header>


