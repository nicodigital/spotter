--- 
import Button from "../../components/Button.astro";

const features = [
  { name: "Monitoreo por alertas de proximidad", pv: true, mon: true },
  { name: "Envío de Móvil de Respuesta Propio", pv: true, mon: true },
  { name: "Llamado al 911", pv: true, mon: true },
  { name: "Disuasión por altoparlantes", pv: true, mon: true },
  { name: "Atención a distancia de portería", pv: true, mon: false },
  { name: "Apertura remota de accesos peatonales", pv: true, mon: false },
  { name: "Apertura y cierre de accesos vehiculares", pv: true, mon: false },
  { name: "Llegada asistida por CCTV", pv: true, mon: true },
  { name: "Alerta de puerta abierta", pv: true, mon: true },
  { name: "Gestión de encomiendas y proveedores", pv: true, mon: false },
  { name: "Comunicación con servicios de mantenimiento", pv: true, mon: false },
  { name: "APP Spotter", pv: true, mon: false },
  { name: "Acceso a cámaras de video", pv: true, mon: true },
  { name: "Envío de Informes y Auditorías", pv: true, mon: true },
  { name: "Alerta de elevador detenido", pv: true, mon: false, optional: true },
  { name: "Guardia Físico de reten", pv: true, mon: true, optional: true },
  { name: "Servicio de Limpieza", pv: true, mon: true, optional: true },
];

const pvTotal = features.filter((f) => f.pv).length;
const monTotal = features.filter((f) => f.mon).length;
const totalFeatures = features.length;
--- 

<section class="relative bg-primary-dark pt-20 pb-40 xg:py-60" data-back="dark">
    <div class="relative bg-ivory-dark py-30 xg:py-60 mask-round shadow-2xl overflow-hidden z-30">

      <!-- Header -->
      <div class="text-center px-20 xg:px-80 mb-20 xg:mb-40">
        <span class="font-[var(--font-sans)] text-base leading-[1.5] font-semibold text-primary mb-6 block">
          Comparativa
        </span>
        <h2 class="title mb-10 xg:mb-16 anim" data-anim="bottom">
          Características
        </h2>
        <p class="text-lg text-gray-500 xg:w-[40%] mx-auto anim" data-anim="bottom" data-delay="0.15">
          Conocé las diferencias entre nuestros servicios y elegí el que mejor se adapte a tus necesidades.
        </p>
      </div>


      <!-- Comparison Table -->
      <div class="px-10 xg:px-80">

        <!-- Table Header (mobile) -->
        <div class="flex xg:hidden justify-end gap-4 px-12 pb-6 mb-4 border-b border-gray-200">
          <span class="w-[5rem] text-center text-xs font-bold text-primary leading-tight">Portería<br/>Virtual</span>
          <span class="w-[5rem] text-center text-xs font-bold text-gray-400 leading-tight">Monitoreo</span>
        </div>

        <!-- Table Header (desktop) -->
        <div class="comp-row hidden xg:grid grid-cols-[1fr_10rem_10rem] xg:grid-cols-[1fr_14rem_14rem] gap-4 px-12 py-8 mb-4 text-primary">
          <span class="text-sm font-semibold uppercase tracking-wider">Prestación</span>
          <span class="text-sm font-semibold text-center uppercase tracking-wider">P. Virtual</span>
          <span class="text-sm font-semibold text-center uppercase tracking-wider">Monitoreo</span>
        </div>

        <!-- Table Rows -->
        {features.map((feature, i) => {
          const isExclusive = feature.pv && !feature.mon;
          const isOptional = feature.optional;
          const isFirstOptional = isOptional && (i === 0 || !features[i - 1]?.optional);
          return (
            <>
              {isFirstOptional && (
                <div class="flex justify-center gap-8 px-12 py-8 mb-4 mt-30">
                  <span class="font-semibold text-primary uppercase tracking-widest shrink-0">Opcionales</span>
                </div>
              )}
              <div
                class:list={[
                  "comp-row grid grid-cols-[1fr_5rem_5rem] xg:grid-cols-[1fr_14rem_14rem] gap-4 items-center px-12 py-8 rounded-2xl [corner-shape:squircle] transition-colors duration-200",
                  i % 2 !== 0 ? "" : "bg-ivory",
                ]}
              >
                <span class="text-base xg:text-md text-gray-700">
                  {feature.name}
                  {isOptional && <span class="text-xs text-gray-400 ml-2 hidden xg:inline">(Opcional)</span>}
                </span>

                <!-- Portería Virtual -->
                <span class="flex justify-center">
                  {feature.pv ? (
                    <svg class="size-11 xg:size-12 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  ) : (
                    <svg class="size-11 xg:size-12 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 6 6 18M6 6l12 12" />
                    </svg>
                  )}
                </span>

                <!-- Monitoreo -->
                <span class="flex justify-center">
                  {feature.mon ? (
                    <svg class="size-11 xg:size-12 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  ) : (
                    <svg class="size-11 xg:size-12 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 6 6 18M6 6l12 12" />
                    </svg>
                  )}
                </span>
              </div>
            </>
          );
        })}
      </div>

       <!-- Score Cards -->
      <div class="grid grid-cols-1 xg:grid-cols-2 gap-12 xg:gap-16 px-20 xg:px-80 my-20 xg:my-30">

        <!-- Portería Virtual Card -->
        <div class="score-card relative flex flex-col items-center gap-8 p-16 xg:p-20 rounded-[3rem] [corner-shape:squircle] bg-primary text-white anim" data-anim="bottom" data-delay="0.1">
          <span class="absolute top-8 right-10 bg-yellow-400 text-primary text-xs font-bold px-8 py-3 rounded-full [corner-shape:squircle]">
            Recomendado
          </span>
          <span class="font-[var(--font-sora)] text-sm font-semibold uppercase tracking-wider opacity-80">
            Portería Virtual
          </span>
          <div class="flex items-baseline gap-2">
            <span class="font-[var(--font-sora)] text-6xl font-bold leading-none">{pvTotal}</span>
            <span class="text-2xl opacity-60">/{totalFeatures}</span>
          </div>
          <span class="text-md opacity-70">prestaciones incluidas</span>
        </div>

        <!-- Monitoreo Card -->
        <div class="score-card flex flex-col items-center gap-8 p-16 xg:p-20 rounded-[3rem] [corner-shape:squircle] bg-ivory text-primary anim" data-anim="bottom" data-delay="0.2">
          <span class="font-[var(--font-sora)] text-sm font-semibold uppercase tracking-wider opacity-60 mt-10 xg:mt-0">
            Monitoreo de Seguridad
          </span>
          <div class="flex items-baseline gap-2">
            <span class="font-[var(--font-sora)] text-6xl font-bold leading-none">{monTotal}</span>
            <span class="text-2xl opacity-40">/{totalFeatures}</span>
          </div>
          <span class="text-md opacity-50">prestaciones incluidas</span>
        </div>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col xg:flex-row justify-center items-center gap-8 px-20 xg:px-60 mt-20 xg:mt-40">
        <Button variant="outline_dark" size="lg" href="/monitoreo-de-seguridad">
          <span>Saber más sobre Monitoreo de Seguridad</span>
        </Button>
      </div>

    </div>
  </section>