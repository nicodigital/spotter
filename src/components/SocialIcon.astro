---

<a
  href={href}
  class:list={[
    "inline-flex size-10 items-center justify-center text-white transition-opacity duration-200 hover:opacity-80",
    className,
  ]}
  aria-label={platform}
  target="_blank"
  rel="noopener noreferrer"
>
  <Fragment set:html={icons[platform]} />
</a>
