---
import Logo from "./Logo.astro";
import SocialIcon from "./SocialIcon.astro";

const footerLinks = [
  { label: "Monitoreo de seguridad", href: "#monitoreo" },
  { label: "Portería virtual", href: "#porteria" },
  { label: "Contacto", href: "#contacto" },
  { label: "Trabaja con nosotros", href: "#trabajo" },
];

const legalLinks = [
  { label: "Política de privacidad", href: "#privacidad" },
  { label: "Términos de servicio", href: "#terminos" },
  { label: "Configuración de cookies", href: "#cookies" },
];

const socialLinks = [
  { platform: "facebook" as const, href: "#" },
  { platform: "instagram" as const, href: "#" },
  { platform: "twitter" as const, href: "#" },
  { platform: "linkedin" as const, href: "#" },
  { platform: "youtube" as const, href: "#" },
];
---

<footer class="bg-[#3068F9] px-4 py-12 sm:px-4 sm:py-12 lg:px-8 lg:py-16">
  <div class="mx-auto flex justify-center max-w-[75%] flex-col gap-10">
    <div class="flex flex-col items-center gap-10 text-center lg:flex-row lg:text-left justify-center">
      <div class="flex-1 lg:flex-none">
        <Logo />
      </div>
      
      <nav class="flex flex-col flex-wrap justify-center gap-4 sm:flex-row sm:gap-10">
        {footerLinks.map((link) => (
          <a href={link.href} class="whitespace-nowrap font-[var(--font-public-sans)] text-sm leading-[1.5] font-semibold text-white transition-opacity duration-200 hover:opacity-80">{link.label}</a>
        ))}
      </nav>
      
      <div class="flex flex-1 justify-center gap-3 lg:flex-none lg:justify-end">
        {socialLinks.map((social) => (
          <SocialIcon platform={social.platform} href={social.href} />
        ))}
      </div>
    </div>
    
    <div class="flex flex-col items-center gap-8">
      <div class="h-px w-full bg-white/20"></div>
      <div class="flex flex-col flex-wrap justify-center gap-3 sm:flex-row sm:gap-6">
        {legalLinks.map((link) => (
          <a href={link.href} class="font-[var(--font-public-sans)] text-sm leading-[1.5] text-white transition-opacity duration-200 hover:opacity-80 hover:underline">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
