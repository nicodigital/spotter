---
import Logo from "./Logo.astro";
import SocialIcon from "./SocialIcon.astro";

const footerLinks = [
  { label: "Monitoreo de seguridad", href: "#monitoreo" },
  { label: "Portería virtual", href: "#porteria" },
  { label: "Contacto", href: "#contacto" },
  { label: "Trabaja con nosotros", href: "#trabajo" },
];

const legalLinks = [
  { label: "Política de privacidad", href: "#privacidad" },
  { label: "Términos de servicio", href: "#terminos" },
  { label: "Configuración de cookies", href: "#cookies" },
];

const socialLinks = [
  { platform: "facebook" as const, href: "#" },
  { platform: "instagram" as const, href: "#" },
];
---

<footer class="bg-[#3068F9] px-4 py-12 xg:px-8 xg:py-16">
  <div class="mx-auto flex justify-center max-w-[75%] flex-col gap-10">
    <div class="flex flex-col items-center gap-30 text-center xg:flex-row xg:text-left justify-center">
      <div class="flex-1 xg:flex-none">
        <Logo />
      </div>
      
      <nav class="flex flex-col flex-wrap justify-center gap-4 xg:flex-row xg:gap-20">
        {footerLinks.map((link) => (
          <a href={link.href} class="whitespace-nowrap font-[var(--font-public-sans)] text-base leading-[1.5] font-semibold text-white transition-opacity duration-200 hover:opacity-80">{link.label}</a>
        ))}
      </nav>
      
      <div class="flex flex-1 justify-center gap-3 xg:flex-none xg:justify-end">
        {socialLinks.map((social) => (
          <SocialIcon platform={social.platform} href={social.href} />
        ))}
      </div>
    </div>
    
    <div class="flex flex-col items-center gap-8">

      <div class="w-full h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

      <div class="flex flex-col flex-wrap justify-center gap-3 xg:flex-row xg:gap-20">
        {legalLinks.map((link) => (
          <a href={link.href} class="text-sm text-white opacity-50 transition-opacity duration-200 hover:opacity-100 hover:underline">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
