---

interface Props {
  navLinks: {
    label: string;
    href: string;
    hasDropdown?: boolean;
  }[];
}

const { navLinks } = Astro.props;

---

<nav class="menu hidden xg:flex items-center gap-8 xg:gap-25">
  {
    navLinks.map((link) => (
      <a href={link.href} class="m-item link">
        {link.label}
        {link.hasDropdown && <ChevronDown class="size-6" />}
      </a>
    ))
  }
</nav>
