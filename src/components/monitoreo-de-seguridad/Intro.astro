---
import Grid from "../../components/Grid.astro";
import CardIcon from "../../components/CardIcon.astro";
---

<section
  class="relative bg-primary-dark text-white pt-90 sm:pt-50 xg:pt-70 2xl:pt-90"
  data-back="dark"
>
  <div class="container-short flex flex-col items-center gap-16">
    <div class="xg:max-w-[80%] text-center mb-10 xg:mb-35">
      <h2 class="title mb-10 xg:mb-20 anim" data-anim="bottom">
        Monitoreo de seguridad
      </h2>
      <p
        class="xg:text-lg w-[90%] xg:w-[66%] mx-auto anim"
        data-anim="bottom"
        data-delay="0.2"
      >
        Optimice la seguridad y reduzca costos operativos de su propiedad.
      </p>
    </div>
  </div>

  <Grid class="invert grayscale opacity-50 z-20" />

  <!-- Video background -->
  <div class="relative overflow-hidden z-10">
    <div class="container relative z-30">
      <div class="grid w-[85%] mx-auto grid-cols-1 gap-30 xg:grid-cols-4 my-30">
        <CardIcon
          icon="camera"
          title="Cámaras en <br> perímetro exterior"
          description="Las cámaras en el perímetro exterior permiten generar zonas seguras y detectar en tiempo real cualquier actividad no deseada."
        />

        <CardIcon
          icon="speakers-2"
          title="Alto parlantes de <br> gran potencia"
          description="Se instalan en los puntos estratégicos para alertar los ingresos no deseados y disuadir la intrusión."
        />

        <CardIcon
          icon="monitoring"
          title="Monitoreo y videovigilancia activa 24/7"
          description="Por eventos de proximidad en perímetro exterior."
        />

        <CardIcon
          icon="support"
          title="Comunicación <br> directa"
          description="De los propietarios con nuestro centro de monitoreo."
        />
      </div>

      <div class="grid w-[85%] mx-auto grid-cols-1 gap-30 xg:grid-cols-4">
        <CardIcon
          icon="panic"
          title="Llamada de <br> alerta"
          description="A uno o más propietarios ante situaciones de pre-pánico."
        />

        <CardIcon
          icon="home-safe"
          title="Privacidad"
          description="Para los propietarios."
        />

        <CardIcon
          icon="notifications"
          title="Envío de <br> notificaciones"
          description="Lo que puede incluir imágenes y alertas de situaciones no deseadas."
        />

        <CardIcon
          icon="cam-outdoor"
          title="Acompañamiento <br> mediante CCTV"
          description="En tiempo real de ingresos de vehículos y peatones."
        />
      </div>
    </div>

    <!-- video background -->
    <video
      class="absolute top-0 left-0 w-full h-full opacity-50 object-cover"
      src="/video/hero.mp4"
      autoplay
      muted
      loop></video>
    <div
      class="absolute w-full left-0 top-0 h-full bg-gradient-to-t from-transparent to-primary-dark z-10 pointer-events-none"
    >
    </div>
    <div
      class="absolute w-full left-0 bottom-0 h-full bg-gradient-to-b from-transparent to-primary-dark z-10 pointer-events-none"
    >
    </div>
  </div>
</section>
