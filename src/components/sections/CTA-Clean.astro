---
// import { Image } from "astro:assets";
import Button from "../Button.astro";
import MoneySheetsIcon from "../../assets/icons/money-sheets.svg";
import WhatsappIcon from "../../assets/icons/whatsapp.svg";
import Grid from "../Grid.astro";
// import CentralBlue from "../../assets/images/central-blue.jpg";
---

<section class="relative flex justify-center" id="contacto">
  <div class="relative container">
    <div
      class="relative p-20 xg:py-40 xg:px-60 z-20 overflow-hidden"
    >

      <div
        class="relative flex flex-col xg:flex-row justify-between items-center  xg:grid-cols-2 xg:text-left z-50"
      >
        <div
          class="flex flex-col gap-6 xg:w-[50%] xg:translate-y-[.5rem]"
        >
          <h2 class="title mb-10 xg:mb-6">
            Protege lo <br />
            que importa
          </h2>
          <p class="text-lg xg:w-[80%] mb-40 xg:mb-0 leading-[1.3]">
            Contacta con nuestro equipo y descubre cómo <br class="hidden xg:block" />Spotter protege lo
            que más importa.
          </p>
        </div>

        <div
          class="flex items-center gap-8 xg:items-start w-full xg:w-[40%] justify-end"
        >
          <div class="flex w-full flex-col gap-8 sm:w-auto sm:flex-row">
            <Button variant="primary" size="lg" class="w-full xg:w-fit" href="#presupuesto">
              <MoneySheetsIcon class="hidden sm:block"/>
              <span>Solicitar presupuesto</span>
            </Button>
            <Button variant="outline_dark" size="lg" class="w-full xg:w-fit" href="tel:+123456789">
              <WhatsappIcon />
              <span>Hablamos</span>
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <Grid />
</section>
