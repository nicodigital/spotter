---
import { Image } from "astro:assets";
import Faqs from "../../assets/images/faqs-2.jpg";

interface FaqItem {
  question: string;
  answer: string;
}

const faqs: FaqItem[] = [
  {
    question: "¿Qué beneficios tiene mi edificio al contratar Spotter?",
    answer:
      "Su edificio será más seguro, con una protección en tiempo real para prevenir eventos de seguridad antes de que sucedan. Además, proporcionamos soluciones de acceso ágiles y seguras, junto con servicios adicionales como la recepción de paquetes y la coordinación de reparaciones. Nuestro sistema puede reducir los gastos comunes hasta en un 70%.",
  },
  {
    question:
      "¿Qué debo evaluar antes de contratar un servicio de portería o vigilancia?",
    answer:
      "Solidez tecnológica: Spotter utiliza software de videovigilancia de última generación y un sistema de información y gestión propio para brindar servicios de portería en edificios. Seguridad real: Contamos con conexión directa a centros de respuesta para despachar móviles de seguridad en segundos. Trayectoria y servicio: Con miles de usuarios mensuales, Spotter cuenta con un equipo especializado y un alto índice de recomendación por parte de nuestros clientes.",
  },
  {
    question: "¿Cómo funciona la seguridad?",
    answer:
      "Spotter previene eventos de seguridad mediante una protección perimetral con cámaras que cuentan con analíticas de inteligencia artificial. Ante una actividad sospechosa, un operador del centro de monitoreo disuade utilizando el altoparlante. Si persiste la amenaza, se envía un móvil de respuesta de inmediato. Además, contamos con personal y vehículos propios para abordar cualquier eventualidad.",
  },
  {
    question: "¿Cuáles son los pasos a seguir para contratar?",
    answer:
      "Puede solicitar más información sobre nuestros planes a través del formulario de contacto y nuestro equipo comercial se pondrá en contacto a la brevedad con una propuesta preliminar. En una segunda instancia, visitamos su edificio para elaborar una propuesta más personalizada, evacuamos cualquier duda con la comisión o administración y podemos asistir a la asamblea de copropietarios para explicar de primera mano los beneficios de contar con Spotter en su edificio.",
  },
];

interface Props {
  allowMultiple?: boolean;
}

const { allowMultiple = false } = Astro.props;
---

<section
  id="faq"
  class="relative bg-ivory-dark text-primary pb-20"
>

<div class="container  flex justify-center">
    <div
      class="w-full h-px mx-auto bg-gradient-to-r from-transparent via-primary/40 to-transparent"
    >
    </div>
  </div>

  <div class="container relative flex flex-col xg:flex-row justify-end py-30 xg:py-60 z-20">
    <div class="xg:w-[50%] h-full xg:pl-60 xg:pr-30 mb-40 xg:mb-0">
      <Image
        class="w-full xg:!h-[90vh] object-cover rounded-[6rem] [corner-shape:squircle]"
        src={Faqs}
        alt="Portería Virtual"
        widths={[1920]}
        sizes="(min-width: 1280px) 35vw, 90vw"
        format="webp"
      />
    </div>
    <div class="w-full xg:w-[50%] xg:px-30">
      <!-- title -->
      <div class="flex flex-col">
        <h2 class="title mb-10 xg:mb-20 anim" data-anim="bottom">
          Preguntas <br class="xg:hidden" /> frecuentes
        </h2>
        <p
          class="text-lg w-[90%] xg:w-[75%] anim"
          data-anim="bottom"
          data-delay="0.2"
        >
          Aquí encontrarás las respuestas a las preguntas más comunes sobre
          nuestros servicios y cómo podemos ayudarte.
        </p>
      </div>

      <!-- faqs -->
      <div
        class="faq-container pt-20 xg:pt-40"
        data-allow-multiple={allowMultiple.toString()}
      >
        {
          faqs.map((faq, index) => (
            <div
              class="faq-item group border-t border-primary/20 anim"
              data-anim="bottom"
              data-children="true"
              data-delay={`${0.1 * (index + 1)}`}
            >
              <button
                class="faq-trigger w-full flex items-center justify-between gap-20 py-25 xg:py-20 text-left cursor-pointer transition-colors duration-300 hover:text-primary/80"
                aria-expanded="false"
              >
                <span class="text-lg xg:text-xl font-sora font-medium w-[75%] xg:w-[66%]">
                  {faq.question}
                </span>
                <span class="faq-icon relative size-12 xg:size-14 shrink-0 rounded-full border border-primary/30 transition-all duration-300 ease-out group-hover:border-primary/60">
                  <span class="faq-icon-line faq-icon-horizontal absolute top-1/2 left-1/2 w-[45%] h-[2px] bg-primary" />
                  <span class="faq-icon-line faq-icon-vertical absolute top-1/2 left-1/2 w-[2px] h-[45%] bg-primary" />
                </span>
              </button>
              <div
                class="faq-content overflow-hidden transition-all duration-500 ease-out"
                style="height: 0;"
              >
                <div class="faq-answer pb-25 xg:pb-35 pr-20 xg:pr-80">
                  <p class="text-base xg:text-md text-primary leading-relaxed">
                    {faq.answer}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
  
</section>

<style>
  .faq-icon-line {
    transform-origin: center;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.2s ease;
  }

  .faq-icon-horizontal {
    transform: translate(-50%, -50%) scaleX(1);
  }

  .faq-icon-vertical {
    transform: translate(-50%, -50%) scaleY(1);
  }

  .faq-item.is-open .faq-icon-vertical {
    transform: translate(-50%, -50%) scaleY(0);
    opacity: 0;
  }

  .faq-item.is-open .faq-icon-horizontal {
    transform: translate(-50%, -50%) scaleX(0.92);
  }

  .faq-item.is-open .faq-icon {
    transform: rotate(180deg);
    background-color: color-mix(in srgb, primary, transparent 90%);
    border-color: color-mix(in srgb, primary, transparent 50%);
  }

  .faq-item.is-open .faq-trigger {
    color: primary;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const containers = document.querySelectorAll(".faq-container");

    containers.forEach((container) => {
      const allowMultiple =
        (container as HTMLElement).dataset.allowMultiple === "true";
      const items = container.querySelectorAll(".faq-item");

      items.forEach((item) => {
        const trigger = item.querySelector(".faq-trigger");
        const content = item.querySelector(".faq-content") as HTMLElement;
        const answer = item.querySelector(".faq-answer") as HTMLElement;

        if (!trigger || !content || !answer) return;

        trigger.addEventListener("click", () => {
          const isOpen = item.classList.contains("is-open");

          // Si no permite múltiples abiertos, cerrar los demás
          if (!allowMultiple && !isOpen) {
            items.forEach((otherItem) => {
              if (
                otherItem !== item &&
                otherItem.classList.contains("is-open")
              ) {
                closeItem(otherItem);
              }
            });
          }

          // Toggle del item actual
          if (isOpen) {
            closeItem(item);
          } else {
            openItem(item);
          }
        });
      });
    });

    function openItem(item: Element) {
      const content = item.querySelector(".faq-content") as HTMLElement;
      const answer = item.querySelector(".faq-answer") as HTMLElement;
      const trigger = item.querySelector(".faq-trigger");

      if (!content || !answer || !trigger) return;

      item.classList.add("is-open");
      trigger.setAttribute("aria-expanded", "true");
      content.style.height = answer.offsetHeight + "px";
    }

    function closeItem(item: Element) {
      const content = item.querySelector(".faq-content") as HTMLElement;
      const trigger = item.querySelector(".faq-trigger");

      if (!content || !trigger) return;

      item.classList.remove("is-open");
      trigger.setAttribute("aria-expanded", "false");
      content.style.height = "0";
    }
  });
</script>
