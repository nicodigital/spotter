---
import Button from "../Button.astro";

interface Props {
  tagline?: string;
  title: string;
  description: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  backgroundImage?: string;
}

const {
  title = "Vigilancia en tiempo real",
  description = "Spotter es la solución de portería virtual y monitoreo de seguridad para tu propiedad. Nuestro equipo de profesionales te protege las 24 horas.",
  primaryCta = { label: "Solicitar presupuesto", href: "#presupuesto" },
  secondaryCta = { label: "Saber más", href: "#servicios" },
  backgroundImage = "/video/video.mp4"
} = Astro.props;
---

<section class="relative flex h-screen items-center overflow-hidden px-4 py-16 sm:min-h-[500px] sm:px-4 sm:py-16 lg:px-8 lg:py-20">
  <div class="absolute inset-0 z-0">
    <video class="w-full h-full object-cover grayscale" src={backgroundImage} autoplay muted loop></video>
    <div class="absolute inset-0 bg-[color-mix(in_srgb,var(--color-primary),transparent_30%)]"></div>
  </div>
  
  <div class="relative mx-auto flex w-full max-w-[1280px] flex-col items-center lg:mt-[-4rem] z-20">
    <div class="flex max-w-[768px] flex-col items-center gap-4 text-center">
      <h1 class="big-title text-white" set:html={title.replace(/\n/g, '<br />')} />
      <p class="mt-2 lg:mt-6 font-[var(--font-public-sans)] text-base leading-[1.5] text-white lg:text-[18px]">{description}</p>
      
      <div class="mt-3 lg:mt-8 flex w-full flex-col gap-4 sm:w-auto sm:flex-row">
        <Button variant="white" size="lg" href={primaryCta.href}>
          {primaryCta.label}
        </Button>
        <Button variant="outline" size="lg" href={secondaryCta.href}>
          {secondaryCta.label}
        </Button>
      </div>
    </div>
  </div>

  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary z-10 pointer-events-none z-10"></div>
</section>
