---
import { Image } from "astro:assets";
import FeaturesImage from "../assets/images/fachada.jpg";
import SupportIcon from "../assets/icons/support.svg";
import NotificationsIcon from "../assets/icons/notifications.svg";
import CamOutdoorIcon from "../assets/icons/cam-outdoor.svg";
import CameraIcon from "../assets/icons/camera.svg";

const features = [
  {
    id: 1,
    title: "Atención de Portería<br>en forma remota",
    description:
      "Para el acceso de personas al edificio, previa autorización del propietario (visitas, delivery, así como servicios y proveedores del estado y del edificio).",
    icon: SupportIcon,
  },
  {
    id: 2,
    title: "Envío de<br>notificaciones",
    description:
      "Comunicación bidireccional con los operadores de nuestro centro de monitoreo. Lo que puede incluir imágenes y alertas de situaciones no deseadas.",
    icon: NotificationsIcon,
  },
  {
    id: 3,
    title: "Cámaras en perímetro<br>exterior",
    description:
      "Las cámaras perimetrales generan mapas de acción y zonas seguras. Con Deep Learning, detectan en tiempo real cualquier actividad dentro de esas áreas.",
    icon: CamOutdoorIcon,
  },
  {
    id: 4,
    title: "Monitoreo y videovigilancia<br>activa 24/7",
    description: "Por eventos de proximidad en perímetro exterior, con disuasión activa a través de parlantes.",
    icon: CameraIcon,
  },
];
---

<section class="relative h-screen bg-black overflow-hidden shadow-xxxl" data-back="dark">
  <figure
    class="absolute top-0 left-0 xg:relative rellax h-full parallax"
    data-speed="-0.2" data-speed-mobile="0"
  >
    <Image
      src={FeaturesImage}
      class="!h-full w-full object-cover z-0 xg:scale-[1.2] opacity-75"
      alt="Features"
    />
  </figure>
  <div class="dot-wrapper">
    {
      features.map((feature) => {
        const IconComponent = feature.icon;
        return (
          <div class={`dot dot-${feature.id}`}>
            <h3 set:html={feature.title} />
            <p>{feature.description}</p>
            <figure>
              <IconComponent />
            </figure>
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .dot-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    height: 100%;
    padding: 8rem 4rem;
  }
  .dot {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-left: 6rem;
    padding-block: 2rem;
    z-index: 20;
    color: white;
    user-select: none;

    h3 {
      font-size: var(--text-lg);
      font-family: var(--font-sora);
      width: fit-content;
      color: white;
      line-height: 1.2;
    }

    p {
      font-size: var(--text-base);
      width: 75%;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition:
        max-height 0.4s ease,
        opacity 0.3s ease,
        margin 0.3s ease;
      margin: 0;
    }

    figure {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      top: 1.5rem;
      left: -3rem;
      width: 7.5rem;
      height: 7.5rem;
      transform: translateY(-1rem);
    }

    svg {
      width: 4.5rem;
      height: 4.5rem;
      color: white;
      z-index: 1;
    }

    &:hover p {
      max-height: 200px;
      opacity: 1;
      margin-top: 0.5rem;
    }
  }

  @media (min-width: 992px) {
    .dot-wrapper {
      position: absolute;
      padding: 0;
      inset: 0;
    }
    h3 {
      font-size: var(--text-xl) !important;
    }
    p{
      font-size: var(--text-md) !important;
    }
    .dot {
      position: absolute;
      width: 25%;
      padding-inline: 0;
      padding-block: 0;

      figure {
        top: 0 !important;
        left: -10rem !important;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50%;

        &::before,
        &::after {
          content: "";
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          border: 1px solid rgba(255, 255, 255, 0.8);
          border-radius: 50%;
          animation: pulse-ring 4s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
        }

        &::after {
          animation-delay: 2s;
        }
      }
    }

    .dot-1 {
      top: 20%;
      left: 30%;
    }

    .dot-2 {
      top: 53%;
      left: 23%;
    }

    .dot-3 {
      top: 33%;
      left: 61%;
    }

    .dot-4 {
      top: 67%;
      left: 52%;
    }
  }

  @keyframes pulse-ring {
    0% {
      opacity: 0;
      width: 7.5rem;
      height: 7.5rem;
    }
    10% {
      opacity: 0.75;
    }
    100% {
      opacity: 0;
      width: 13rem;
      height: 13rem;
    }
  }
</style>
