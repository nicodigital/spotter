---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/sections/Hero.astro";
import HowItWorks from "../components/sections/HowItWorks.astro";
import Benefits from "../components/sections/Benefits.astro";
import Servicios from "../components/sections/Servicios.astro";
import Tutoriales from "../components/sections/Tutoriales.astro";
// import Video from "../components/sections/Video.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import CTA from "../components/sections/CTA.astro";
---

<Layout title="Spotter - Vigilancia en tiempo real">
  <Header />
  <main class="bg-primary">
    <Hero 
      tagline="Seguridad"
      title="Vigilancia<br />en tiempo real"
      description="Spotter es la solución de portería virtual y monitoreo de seguridad para tu propiedad. Nuestro equipo de profesionales te protege las 24 horas."
    />
    <HowItWorks />
    <Benefits />
    <Servicios />
    <Tutoriales />
    <!-- <Video /> -->
    <Testimonials />
    <CTA />
  </main>
  <Footer />
</Layout>
